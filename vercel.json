{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "api.py"
    }
  ],
  "functions": {
    "api.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "APP_ENV": "production",
    "DEPLOYMENT_ID": "stateless-deployment-v3"
  }
}
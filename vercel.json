{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "api/index.py"
    }
  ],
  "functions": {
    "api/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "APP_ENV": "production",
    "AURA_SYNC_PULSE": "v6-glob-pattern"
  }
}